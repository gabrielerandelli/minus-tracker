{
  "name": "@gabrielerandelli/minus-tracker",
  "version": "0.5.7",
  "description": "Italian capital-gains/loss calculator for the Regime Dichiarativo",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    }
  },
  "bin": {
    "minus-tracker": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "samples"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-assets.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "keywords": [
    "capital-gains",
    "plusvalenze",
    "minusvalenze",
    "regime-dichiarativo",
    "degiro",
    "tax",
    "italy",
    "csv",
    "lifo",
    "fifo",
    "typescript"
  ],
  "homepage": "https://github.com/gabrielerandelli/minus-tracker#readme",
  "bugs": {
    "url": "https://github.com/gabrielerandelli/minus-tracker/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielerandelli/minus-tracker.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
