{
  "name": "@gabrielerandelli/minus-tracker",
  "version": "0.8.3",
  "description": "Italian capital-gains/loss calculator (LIFO/FIFO) with CLI and MCP server for AI agents — Regime Dichiarativo",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "minus-tracker": "./dist/cli/index.js",
    "minus-tracker-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist",
    "samples"
  ],
  "scripts": {
    "build": "node scripts/generate-mcp-schemas.js && tsup && node scripts/copy-assets.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "ts-json-schema-generator": "^2.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "MIT",
  "keywords": [
    "capital-gains",
    "plusvalenze",
    "minusvalenze",
    "regime-dichiarativo",
    "degiro",
    "tax",
    "italy",
    "csv",
    "lifo",
    "fifo",
    "typescript",
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "ai-agent",
    "llm-tools",
    "claude",
    "tax-calculator"
  ],
  "homepage": "https://github.com/gabrielerandelli/minus-tracker#readme",
  "bugs": {
    "url": "https://github.com/gabrielerandelli/minus-tracker/issues"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielerandelli/minus-tracker.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  }
}
